    if "perp_key" in tmp.columns:
        agg_parts["n_perps"] = ("perp_key", pd.Series.nunique)

    agg_parts["n_rows"] = ("referral_id", "size")

    referral_complexity = tmp.groupby("referral_id").agg(**agg_parts).reset_index()

    if set(["n_allegations", "n_perps"]).issubset(referral_complexity.columns):
        referral_complexity["allegation_x_perp"] = (
            referral_complexity["n_allegations"].fillna(0) *
            referral_complexity["n_perps"].fillna(0)
        )
        referral_complexity["row_explosion_ratio"] = (
            referral_complexity["n_rows"] / referral_complexity["allegation_x_perp"].replace(0, np.nan)
        )
        print("\nReferral complexity sample:")

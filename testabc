import pandas as pd
import numpy as np

def split_semicolon_values(x):
    if pd.isna(x):
        return []
    x = str(x).strip()
    if x == "":
        return []
    return [i.strip() for i in x.split(";") if i.strip() != ""]


df_long = df_long.copy()
z = z.copy()

if "is_matched" not in df_long.columns:
    df_long["is_matched"] = False

all_updates = []

for _, row in z.iterrows():
    long_person_id_x = row["LONG_PERSON_ID_x"]
    referral_id_x = row["referral_id_x"]
    person_id_x = row["person_id_x"]

    # 1. add the source row itself
    all_updates.append({
        "referral_id": referral_id_x,
        "person_id": person_id_x,
        "LONG_PERSON_ID_new": long_person_id_x
    })

    # 2. add the likely matched target rows
    ref_list = split_semicolon_values(row["likely_matched_referral_ids"])
    per_list = split_semicolon_values(row["likely_matched_person_ids"])

    n = min(len(ref_list), len(per_list))

    for i in range(n):
        all_updates.append({
            "referral_id": ref_list[i],
            "person_id": per_list[i],
            "LONG_PERSON_ID_new": long_person_id_x
        })

update_df = pd.DataFrame(all_updates)

if not update_df.empty:
    # align types
    update_df["referral_id"] = update_df["referral_id"].astype(df_long["referral_id"].dtype)
    update_df["person_id"] = update_df["person_id"].astype(df_long["person_id"].dtype)

    # remove duplicates
    update_df = update_df.drop_duplicates(subset=["referral_id", "person_id", "LONG_PERSON_ID_new"])

    # if same df_long row appears multiple times, keep first
    update_df = update_df.drop_duplicates(subset=["referral_id", "person_id"], keep="first")

    df_long = df_long.merge(
        update_df,
        how="left",
        on=["referral_id", "person_id"]
    )

    mask = df_long["LONG_PERSON_ID_new"].notna()

    # update BOTH source and target rows to LONG_PERSON_ID_x
    df_long.loc[mask, "LONG_PERSON_ID"] = df_long.loc[mask, "LONG_PERSON_ID_new"]
    df_long.loc[mask, "is_matched"] = True

    df_long.drop(columns=["LONG_PERSON_ID_new"], inplace=True)

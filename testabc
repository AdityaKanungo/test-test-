# Hessian for standard errors
fit_hessian <- optim(
  par = coef_values,
  fn = neg_loglik,
  X = X,
  y = y,
  method = "L-BFGS-B",
  hessian = TRUE,
  control = list(maxit = 100)
)

vcov_mat <- solve(fit_hessian$hessian)
std_err <- sqrt(diag(vcov_mat))

z_values <- coef_values / std_err
p_values <- 2 * (1 - pnorm(abs(z_values)))

ci_lower <- coef_values - 1.96 * std_err
ci_upper <- coef_values + 1.96 * std_err

odds_ratio <- exp(coef_values)

intercept <- coef_values["const"]

predicted_probability <- ifelse(
  names(coef_values) == "const",
  plogis(intercept),
  plogis(intercept + coef_values)
)

final_results <- data.frame(
  subcategory = names(coef_values),
  coef = round(coef_values, 3),
  std_err = round(std_err, 3),
  z = round(z_values, 3),
  p_value = round(p_values, 3),
  ci_lower = round(ci_lower, 3),
  ci_upper = round(ci_upper, 3),
  odds_ratio = round(odds_ratio, 3),
  predicted_probability_percent = round(predicted_probability * 100, 2),
  row.names = NULL
)

print(final_results)

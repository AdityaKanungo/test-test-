    df["perp_ssn_last4"] = np.nan

def build_perp_key(row):
    # Priority 1: SSN if present
    if pd.notna(row.get("perp_social_security_number")) and row.get("perp_social_security_number") != "nan":
        return f"ssn::{row['perp_social_security_number']}"
    # Priority 2: name + dob
    fn = row.get("perp_first_name")
    ln = row.get("perp_last_name")
    dob = row.get("perp_date_of_birth")
    if pd.notna(fn) or pd.notna(ln) or pd.notna(dob):
        dob_str = dob.strftime("%Y-%m-%d") if pd.notna(dob) else "missingdob"
        return f"name_dob::{fn}|{ln}|{dob_str}"
    return np.nan


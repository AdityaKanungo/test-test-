from __future__ import annotations

import re
from collections import defaultdict
from dataclasses import dataclass
from datetime import datetime
from itertools import combinations
from math import isnan
from typing import Any, Dict, List, Mapping, Optional, Sequence, Set, Tuple

try:
    import pandas as pd
except ImportError:  # pragma: no cover
    pd = None


MISSING_SENTINELS = {
    "",
    "NULL",
    "NONE",
    "N/A",
    "NA",
    "UNKNOWN",
    "UNK",
}

DATE_FORMATS = (
    "%Y-%m-%d",
    "%m/%d/%Y",
    "%m/%d/%y",
    "%m-%d-%Y",
    "%m-%d-%y",
    "%Y/%m/%d",
    "%Y%m%d",
)

DEFAULT_INVALID_SSNS = {
    "000000000",
    "111111111",
    "123456789",
    "999999999",
}

MATCH_YES = "Yes"
MATCH_NO = "No"
MATCH_BLANK = "Blank"

EXACT_SCENARIOS = {0, 1, 2, 3, 4, 5, 6}
LIKELY_SCENARIOS = {7, 8, 9, 10, 11, 12}

SCENARIO_DEFINITIONS: Dict[Tuple[str, str, str, str], int] = {
    (MATCH_YES, MATCH_YES, MATCH_YES, MATCH_YES): 0,
    (MATCH_YES, MATCH_YES, MATCH_NO, MATCH_YES): 1,
    (MATCH_YES, MATCH_NO, MATCH_YES, MATCH_YES): 2,
    (MATCH_NO, MATCH_YES, MATCH_YES, MATCH_YES): 3,
    (MATCH_NO, MATCH_YES, MATCH_BLANK, MATCH_YES): 4,
    (MATCH_NO, MATCH_NO, MATCH_YES, MATCH_YES): 5,
    (MATCH_YES, MATCH_NO, MATCH_BLANK, MATCH_YES): 6,
    (MATCH_NO, MATCH_YES, MATCH_NO, MATCH_YES): 7,
    (MATCH_YES, MATCH_NO, MATCH_NO, MATCH_YES): 8,
    (MATCH_YES, MATCH_NO, MATCH_YES, MATCH_BLANK): 9,
    (MATCH_NO, MATCH_YES, MATCH_YES, MATCH_BLANK): 10,
    (MATCH_NO, MATCH_YES, MATCH_NO, MATCH_BLANK): 11,
    (MATCH_YES, MATCH_YES, MATCH_YES, MATCH_BLANK): 12,
}

NAME_CLEAN_RE = re.compile(r"[^A-Z0-9]")


@dataclass(frozen=True)
class ReferralColumns:
    referral_id: str = "referral_id"
    referral_type: str = "referral_type"
    first_name: str = "FN"
    last_name: str = "LN"
    ssn: str = "SSN"
    dob: str = "DOB"


@dataclass
class PreparedReferral:
    row_number: int
    raw_row: Dict[str, Any]
    referral_id: str
    referral_type: str
    first_name: Optional[str]
    last_name: Optional[str]
    ssn: Optional[str]
    dob: Optional[str]


@dataclass(frozen=True)
class PairMatch:
    left_index: int
    right_index: int
    left_referral_id: str
    right_referral_id: str
    scenario_id: int
    match_type: str
    is_match: bool
    is_likely: bool
    fn_match: str
    ln_match: str
    dob_match: str
    ssn_match: str


@dataclass
class MatchResult:
    referrals: List[PreparedReferral]
    pair_matches: List[PairMatch]
    person_ids_by_index: Dict[int, str]

    @property
    def exact_match_count(self) -> int:
        return sum(1 for pair in self.pair_matches if pair.is_match)

    @property
    def likely_match_count(self) -> int:
        return sum(1 for pair in self.pair_matches if pair.is_likely)

    def to_pair_rows(self) -> List[Dict[str, Any]]:
        return [
            {
                "left_referral_id": pair_match.left_referral_id,
                "right_referral_id": pair_match.right_referral_id,
                "left_long_person_id": self.person_ids_by_index[pair_match.left_index],
                "right_long_person_id": self.person_ids_by_index[pair_match.right_index],
                "scenario_id": pair_match.scenario_id,
                "match_type": pair_match.match_type,
                "is_match": pair_match.is_match,
                "is_likely": pair_match.is_likely,
                "fn_match": pair_match.fn_match,
                "ln_match": pair_match.ln_match,
                "dob_match": pair_match.dob_match,
                "ssn_match": pair_match.ssn_match,
            }
            for pair_match in self.pair_matches
        ]

    def to_referral_rows(self) -> List[Dict[str, Any]]:
        return [
            {
                **referral.raw_row,
                "long_person_id": self.person_ids_by_index[referral.row_number],
            }
            for referral in self.referrals
        ]


@dataclass
class TableMatchOutput:
    pair_matches: Any
    referrals_with_person_id: Any
    result: MatchResult


class DisjointSet:
    def __init__(self, size: int) -> None:
        self.parent = list(range(size))
        self.rank = [0] * size

    def find(self, item: int) -> int:
        parent = self.parent[item]
        if parent != item:
            self.parent[item] = self.find(parent)
        return self.parent[item]

    def union(self, left: int, right: int) -> None:
        left_root = self.find(left)
        right_root = self.find(right)
        if left_root == right_root:
            return

        left_rank = self.rank[left_root]
        right_rank = self.rank[right_root]

        if left_rank < right_rank:
            self.parent[left_root] = right_root
            return
        if left_rank > right_rank:
            self.parent[right_root] = left_root
            return

        self.parent[right_root] = left_root
        self.rank[left_root] += 1


def normalize_text(value: Optional[Any]) -> Optional[str]:
    if value is None:
        return None

    if isinstance(value, float) and isnan(value):
        return None

    if pd is not None:
        try:
            if bool(pd.isna(value)):
                return None
        except (TypeError, ValueError):
            pass

    text = str(value).strip()
    if not text:
        return None
    upper_text = text.upper()
    if upper_text in MISSING_SENTINELS:
        return None
    return upper_text


def normalize_name(value: Optional[Any]) -> Optional[str]:
    text = normalize_text(value)
    if text is None:
        return None
    cleaned = NAME_CLEAN_RE.sub("", text)
    return cleaned or None


def normalize_ssn(
    value: Optional[Any],
    invalid_ssns: Optional[Set[str]] = None,
) -> Optional[str]:
    text = normalize_text(value)
    if text is None:
        return None

    digits = "".join(character for character in text if character.isdigit())
    if len(digits) != 9:
        return None

    invalid_values = invalid_ssns if invalid_ssns is not None else DEFAULT_INVALID_SSNS
    if digits in invalid_values:
        return None

    return digits


def normalize_dob(value: Optional[Any]) -> Optional[str]:
    text = normalize_text(value)
    if text is None:
        return None

    for date_format in DATE_FORMATS:
        try:
            return datetime.strptime(text, date_format).date().isoformat()
        except ValueError:
            continue

    digits = "".join(character for character in text if character.isdigit())
    if len(digits) == 8:
        for date_format in ("%m%d%Y", "%d%m%Y"):
            try:
                return datetime.strptime(digits, date_format).date().isoformat()
            except ValueError:
                continue

    return text


def name_match_state(left: Optional[str], right: Optional[str]) -> str:
    return MATCH_YES if left is not None and right is not None and left == right else MATCH_NO


def nullable_match_state(left: Optional[str], right: Optional[str]) -> str:
    if left is None or right is None:
        return MATCH_BLANK
    return MATCH_YES if left == right else MATCH_NO


def classify_pair(left: PreparedReferral, right: PreparedReferral) -> Optional[PairMatch]:
    fn_state = name_match_state(left.first_name, right.first_name)
    ln_state = name_match_state(left.last_name, right.last_name)
    dob_state = nullable_match_state(left.dob, right.dob)
    ssn_state = nullable_match_state(left.ssn, right.ssn)

    scenario_id = SCENARIO_DEFINITIONS.get((fn_state, ln_state, dob_state, ssn_state))
    if scenario_id is None:
        return None

    left_index, right_index = sorted((left.row_number, right.row_number))
    left_record = left if left.row_number == left_index else right
    right_record = right if right.row_number == right_index else left

    return PairMatch(
        left_index=left_index,
        right_index=right_index,
        left_referral_id=left_record.referral_id,
        right_referral_id=right_record.referral_id,
        scenario_id=scenario_id,
        match_type="match" if scenario_id in EXACT_SCENARIOS else "likely",
        is_match=scenario_id in EXACT_SCENARIOS,
        is_likely=scenario_id in LIKELY_SCENARIOS,
        fn_match=fn_state,
        ln_match=ln_state,
        dob_match=dob_state,
        ssn_match=ssn_state,
    )


def prepare_referrals(
    rows: Sequence[Mapping[str, Any]],
    columns: ReferralColumns = ReferralColumns(),
    invalid_ssns: Optional[Set[str]] = None,
) -> List[PreparedReferral]:
    prepared_rows: List[PreparedReferral] = []

    for row_number, raw_row in enumerate(rows):
        row_dict = dict(raw_row)
        prepared_rows.append(
            PreparedReferral(
                row_number=row_number,
                raw_row=row_dict,
                referral_id=str(row_dict[columns.referral_id]).strip(),
                referral_type=str(row_dict.get(columns.referral_type, "")).strip(),
                first_name=normalize_name(row_dict.get(columns.first_name)),
                last_name=normalize_name(row_dict.get(columns.last_name)),
                ssn=normalize_ssn(row_dict.get(columns.ssn), invalid_ssns=invalid_ssns),
                dob=normalize_dob(row_dict.get(columns.dob)),
            )
        )

    return prepared_rows


def _compare_all_pairs_in_group(
    indices: Sequence[int],
    referrals: Sequence[PreparedReferral],
    pair_matches: Dict[Tuple[int, int], PairMatch],
    unions: DisjointSet,
) -> None:
    for left_index, right_index in combinations(indices, 2):
        pair_match = classify_pair(referrals[left_index], referrals[right_index])
        if pair_match is None:
            continue

        pair_key = (pair_match.left_index, pair_match.right_index)
        if pair_key in pair_matches:
            continue

        pair_matches[pair_key] = pair_match
        if pair_match.is_match:
            unions.union(pair_match.left_index, pair_match.right_index)


def _compare_anchor_pairs(
    anchor_indices: Sequence[int],
    group_indices: Sequence[int],
    referrals: Sequence[PreparedReferral],
    allowed_scenarios: Set[int],
    pair_matches: Dict[Tuple[int, int], PairMatch],
) -> None:
    seen_pairs: Set[Tuple[int, int]] = set()

    for anchor_index in anchor_indices:
        for candidate_index in group_indices:
            if anchor_index == candidate_index:
                continue

            pair_key = (
                anchor_index
                if anchor_index < candidate_index
                else candidate_index,
                candidate_index
                if anchor_index < candidate_index
                else anchor_index,
            )
            if pair_key in seen_pairs or pair_key in pair_matches:
                continue

            seen_pairs.add(pair_key)
            pair_match = classify_pair(referrals[pair_key[0]], referrals[pair_key[1]])
            if pair_match is None or pair_match.scenario_id not in allowed_scenarios:
                continue

            pair_matches[pair_key] = pair_match


def assign_long_person_ids(
    referrals: Sequence[PreparedReferral],
    unions: DisjointSet,
    prefix: str = "LP",
) -> Dict[int, str]:
    root_to_person_id: Dict[int, str] = {}
    person_ids_by_index: Dict[int, str] = {}
    next_person_number = 1

    for referral in referrals:
        root = unions.find(referral.row_number)
        person_id = root_to_person_id.get(root)
        if person_id is None:
            person_id = f"{prefix}{next_person_number:08d}"
            root_to_person_id[root] = person_id
            next_person_number += 1
        person_ids_by_index[referral.row_number] = person_id

    return person_ids_by_index


def match_referrals(
    referrals: Sequence[PreparedReferral],
    person_id_prefix: str = "LP",
) -> MatchResult:
    pair_matches: Dict[Tuple[int, int], PairMatch] = {}
    unions = DisjointSet(len(referrals))

    ssn_groups: Dict[str, List[int]] = defaultdict(list)
    dob_groups: Dict[str, List[int]] = defaultdict(list)
    ln_groups: Dict[str, List[int]] = defaultdict(list)

    for referral in referrals:
        if referral.ssn is not None:
            ssn_groups[referral.ssn].append(referral.row_number)
        if referral.dob is not None:
            dob_groups[referral.dob].append(referral.row_number)
        if referral.last_name is not None:
            ln_groups[referral.last_name].append(referral.row_number)

    for group_indices in ssn_groups.values():
        if len(group_indices) < 2:
            continue
        _compare_all_pairs_in_group(group_indices, referrals, pair_matches, unions)

    for group_indices in dob_groups.values():
        if len(group_indices) < 2:
            continue

        missing_ssn_indices = [
            index for index in group_indices if referrals[index].ssn is None
        ]
        if not missing_ssn_indices:
            continue

        _compare_anchor_pairs(
            anchor_indices=missing_ssn_indices,
            group_indices=group_indices,
            referrals=referrals,
            allowed_scenarios={9, 10, 12},
            pair_matches=pair_matches,
        )

    for group_indices in ln_groups.values():
        if len(group_indices) < 2:
            continue

        missing_ssn_indices = [
            index for index in group_indices if referrals[index].ssn is None
        ]
        if not missing_ssn_indices:
            continue

        _compare_anchor_pairs(
            anchor_indices=missing_ssn_indices,
            group_indices=group_indices,
            referrals=referrals,
            allowed_scenarios={11},
            pair_matches=pair_matches,
        )

    sorted_pairs = sorted(
        pair_matches.values(),
        key=lambda pair: (pair.scenario_id, pair.left_referral_id, pair.right_referral_id),
    )
    person_ids = assign_long_person_ids(referrals, unions, prefix=person_id_prefix)

    return MatchResult(
        referrals=list(referrals),
        pair_matches=sorted_pairs,
        person_ids_by_index=person_ids,
    )


def _is_pandas_dataframe(value: Any) -> bool:
    return pd is not None and isinstance(value, pd.DataFrame)


def _rows_from_victim_table(victim_table: Any) -> List[Dict[str, Any]]:
    if _is_pandas_dataframe(victim_table):
        return victim_table.to_dict(orient="records")

    if not isinstance(victim_table, Sequence) or isinstance(victim_table, (str, bytes)):
        raise TypeError(
            "victim_table must be a pandas DataFrame or a sequence of row dictionaries."
        )

    rows = [dict(row) for row in victim_table]
    if rows and not isinstance(rows[0], dict):
        raise TypeError(
            "victim_table rows must be mappings when a pandas DataFrame is not used."
        )
    return rows


def match_victim_table(
    victim_table: Any,
    columns: ReferralColumns = ReferralColumns(),
    person_id_prefix: str = "LP",
    invalid_ssns: Optional[Set[str]] = None,
) -> TableMatchOutput:
    rows = _rows_from_victim_table(victim_table)
    referrals = prepare_referrals(rows, columns=columns, invalid_ssns=invalid_ssns)
    result = match_referrals(referrals, person_id_prefix=person_id_prefix)

    if _is_pandas_dataframe(victim_table):
        referrals_with_person_id = victim_table.copy()
        referrals_with_person_id["long_person_id"] = [
            result.person_ids_by_index[index] for index in range(len(result.referrals))
        ]
        pair_matches = pd.DataFrame(result.to_pair_rows())
    else:
        referrals_with_person_id = result.to_referral_rows()
        pair_matches = result.to_pair_rows()

    return TableMatchOutput(
        pair_matches=pair_matches,
        referrals_with_person_id=referrals_with_person_id,
        result=result,
    )

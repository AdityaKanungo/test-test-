# Since no perp_id exists, build a perpetrator fingerprint.
# SSN is sensitive, so use it only if present, else use name+dob.
def normalize_text(s):
    if pd.isna(s):
        return np.nan
    s = str(s).strip().lower()
    s = re.sub(r"\s+", " ", s)
    return s


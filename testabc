import pandas as pd

# df = pd.read_csv("your_file.csv")

# Ensure dates are datetime
date_cols = ["referral_received_date", "incident_begin_date"]
for col in date_cols:
    df[col] = pd.to_datetime(df[col], errors="coerce")

# Keep only children who have a subsequent CPS referral
children_with_subseq_cps = df.loc[
    (df["referral_type"].eq("CPS")) &
    (df["referral_sequence_type"].eq("Subsequent")),
    "long_person_id"
].unique()

df_sub = df[df["long_person_id"].isin(children_with_subseq_cps)].copy()

# Earliest GPS index referral per child
gps_index = (
    df_sub[
        (df_sub["referral_type"].eq("GPS")) &
        (df_sub["referral_sequence_type"].eq("Index"))
    ]
    .groupby("long_person_id", as_index=False)
    .agg(
        gps_referral_received_date=("referral_received_date", "min"),
        gps_incident_begin_date=("incident_begin_date", "min")
    )
)

# Earliest subsequent CPS referral per child
cps_subseq = (
    df_sub[
        (df_sub["referral_type"].eq("CPS")) &
        (df_sub["referral_sequence_type"].eq("Subsequent"))
    ]
    .groupby("long_person_id", as_index=False)
    .agg(
        cps_referral_received_date=("referral_received_date", "min"),
        cps_incident_begin_date=("incident_begin_date", "min")
    )
)

# Final dataset
final_df = gps_index.merge(
    cps_subseq,
    on="long_person_id",
    how="inner"
)

final_df
